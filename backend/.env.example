# RiadPricer Backend - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (votre domaine Vercel)
FRONTEND_URL=https://riadpricer.vercel.app
BACKEND_URL=https://your-app.railway.app

# Database PostgreSQL (fourni automatiquement par Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SerpAPI (pour recherche Google Hotels)
SERPAPI_KEY=0e81f7d0c978262396b99676580a7c7991c495439b4e7a10ab9452c82fa776be

# PayZone (a recevoir de support@payzone.ma)
PAYZONE_MERCHANT_ID=Papierentete
PAYZONE_API_KEY=your_api_key_here
PAYZONE_SECRET_KEY=your_secret_key_here
PAYZONE_PAYLINK_URL=https://pay.payzone.ma

# Admin (pour confirmations manuelles)
ADMIN_SECRET=riadpricer_admin_2026
